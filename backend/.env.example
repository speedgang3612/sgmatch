# ==============================================
# SG Match Backend - 환경 변수 예시
# 이 파일을 복사해서 .env 로 이름 변경 후 사용하세요
# cp .env.example .env
# ==============================================

PORT=8000
ENVIRONMENT=dev
DEBUG=True

DATABASE_URL=sqlite:///./sgmatch.db

# ------------------------------------------------------------------
# [운영 배포] PostgreSQL 로 교체 방법
# ------------------------------------------------------------------
# 아래 DATABASE_URL 주석을 해제하고, 위 SQLite 줄을 주석 처리하세요.
# asyncpg 드라이버 필요: pip install asyncpg
#
# 일반 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
#
# Railway PostgreSQL 예시:
# DATABASE_URL=postgresql+asyncpg://postgres:password@containers-us-west-xx.railway.app:6543/railway
#
# Supabase PostgreSQL 예시:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# ------------------------------------------------------------------

JWT_SECRET_KEY=여기에-안전한-랜덤-문자열-입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

OIDC_ISSUER_URL=http://localhost:8000/oidc
OIDC_CLIENT_ID=local-client-id
OIDC_CLIENT_SECRET=local-client-secret
OIDC_SCOPE=openid email profile
FRONTEND_URL=http://localhost:3000

ADMIN_USER_ID=admin-00000000
ADMIN_USER_EMAIL=admin@sgmatch.co.kr

# 선택 사항
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_test_...

# Redis (Upstash - 토큰 블랙리스트)
# REDIS_URL=redis://default:[TOKEN]@[HOST].upstash.io:6379
